# Acme Health Clinical Reports - Environment Variables
#
# Copy this file to .env and fill in the values.
# Environment variables override values in the properties files.
#
# For production deployments, these are set by the deployment pipeline.
# For local development, you'll need to get credentials from the DBA team.
# Contact: dba-team@acmehealth.com or #dba-support on Slack

# Database connection
DB_HOST=acme-warehouse-prod.internal
DB_PORT=5432
DB_NAME=clinical_warehouse
DB_USER=report_svc
DB_PASSWORD=

# Report paths
REPORT_OUTPUT_DIR=/data/reports/output
REPORT_TEMPLATE_DIR=/opt/acmehealth/reports/templates

# Optional: Path to a .properties config file
# REPORT_CONFIG_PATH=/etc/acmehealth/reports.properties

# SMTP (for automated report delivery)
SMTP_HOST=mail.acmehealth.internal
SMTP_PORT=25
SMTP_FROM=reports@acmehealth.com
